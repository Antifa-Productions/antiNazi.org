{
    "python.analysis.autoTranslateDocstrings": true,
    "python.analysis.completeFunctionParens": true,
    "python.analysis.diagnosticMode": "workspace",
    "editor.accessibilitySupport": "auto",
    "editor.allowVariableFontsInAccessibilityMode": true,
    "editor.autoClosingBrackets": "languageDefined",
    "editor.autoClosingComments": "beforeWhitespace",
    "editor.autoClosingDelete": "auto",
    "editor.autoClosingOvertype": "auto",
    "editor.autoIndent": "full",
    "editor.autoIndentOnPaste": true,
    "editor.codeActions.triggerOnFocusChange": true,
    "editor.codeLensFontFamily": "ui-monospace",
    "editor.experimental.asyncTokenizationLogging": true,
    "github-actions.workflows.pinned.refresh.enabled": true
}